# ──────────────────────────────────────────────────────────────────
# PR Autopilot — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ──────────────────────────────────────────────────────────────────

# ── GitHub App credentials ─────────────────────────────────────────
# Found in: GitHub → Settings → Developer settings → GitHub Apps → Your App

# Your GitHub App's numeric ID (visible in app settings)
GITHUB_APP_ID=123456

# PEM-encoded private key. Generate in App settings → Private keys → Generate.
# Copy the entire key INCLUDING the header/footer lines.
# On Vercel, paste the raw PEM. In .env locally, replace newlines with \n:
# GITHUB_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\nMIIEo...\n-----END RSA PRIVATE KEY-----"
GITHUB_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----
YOUR_PRIVATE_KEY_CONTENT_HERE
-----END RSA PRIVATE KEY-----"

# Webhook secret — set this in App settings → Webhook secret.
# Use a strong random string: openssl rand -hex 32
GITHUB_WEBHOOK_SECRET=your_webhook_secret_here

# ── Anthropic (Claude) ─────────────────────────────────────────────
# Get your key at: https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-your-key-here

# ── Server ────────────────────────────────────────────────────────
PORT=3000
